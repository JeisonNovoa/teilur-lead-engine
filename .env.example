# ===========================================================
# Teilur Lead Engine - Variables de entorno (Fase 1)
# Copia este archivo a ".env" y rellena los valores reales.
# El archivo .env NUNCA se sube a git (está en .gitignore).
# ===========================================================

# --- IA: Google Gemini ---
# Consíguela GRATIS en: https://aistudio.google.com/app/apikey
# Pega aquí la clave que empieza con "AIza..."
GEMINI_API_KEY=

# Modelo a usar (no cambiar salvo que sepas lo que haces)
GEMINI_MODEL=gemini-2.5-flash

# --- Apollo (opcional, para Fase 1b con API directa) ---
# Por ahora usamos CSV exportado, así que esto puede quedar vacío.
# Cuando confirmemos que Apollo es plan pagado, se consigue en:
# Apollo > Settings > Integrations > API
APOLLO_API_KEY=

# --- Configuración de procesamiento ---
# Cuántos leads procesar en paralelo (subir si hay muchos leads y la API aguanta)
CONCURRENCY=3

# Pausa en milisegundos entre lotes (para no exceder límites de la API)
BATCH_DELAY_MS=1000

# ===========================================================
#  DASHBOARD (Fase 2) — solo necesario para correr el dashboard
# ===========================================================

# --- Base de datos (Supabase Postgres) — OBLIGATORIA ---
# La consigues en Supabase > Connect > Connection string (URI).
# Reemplaza [YOUR-PASSWORD] por la contraseña del proyecto.
DATABASE_URL=

# --- Login del dashboard ---
# Contraseña que Melanie escribe para entrar al dashboard.
DASHBOARD_PASSWORD=teilur

# Secreto para firmar la cookie de sesión. Pon cualquier string largo y aleatorio.
# Genera uno con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=
